# Stagging Environment Configuration
# Copy to .env.stagging and fill in values
# Usage: docker compose -f docker-compose.stagging.yml --env-file .env.stagging up -d

# Application URLs - Stagging
CLIENT_URL=https://stagging.crownbankers.com
API_URL=https://stagging.api.crownbankers.com
NEXT_PUBLIC_API_URL=https://stagging.api.crownbankers.com/api/v1
ALLOWED_ORIGINS=https://stagging.crownbankers.com,https://stagging.api.crownbankers.com

# JWT & Auth
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret
ADMIN_JWT_SECRET=your_admin_jwt_secret
ADMIN_JWT_EXPIRES_IN=7d

# Database - Use separate stagging DB if available
MONGODB_URL_DEVELOPMENT=mongodb+srv://user:pass@cluster.mongodb.net/stagging_db
MONGODB_URL_PRODUCTION=mongodb+srv://user:pass@cluster.mongodb.net/stagging_db

# Redis
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password
REDIS_HOST=your_redis_host
REDIS_PORT=your_redis_port

# Email
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password

# NOWPayments - Use sandbox/test credentials for stagging
NOWPAYMENTS_API_KEY=your_stagging_api_key
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_CALLBACK_URL=https://stagging.api.crownbankers.com/api/v1/payment/callback
NOWPAYMENTS_IPN_SECRET=your_ipn_secret

# Node
NODE_ENV=production
PORT=8000
