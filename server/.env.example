# Server environment example (copy to .env and fill in)

NODE_ENV=development
PORT=8000

# Mongo
MONGODB_URL_DEVELOPMENT=mongodb://127.0.0.1:27017/big-bull-energies
# MONGODB_URL_PRODUCTION=

CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# --- Email (Elastic Email API) ---
# Required for delivery. Create key in Elastic Email dashboard.
ELASTICMAIL_API_KEY=

# MUST be on a domain verified in Elastic Email (not gmail.com)
ELASTIC_FROM_EMAIL=noreply@your-verified-domain.com
EMAIL_FROM_NAME=Big Bull Energies
SUPPORT_EMAIL=support@your-verified-domain.com

# Legacy aliases (optional)
# EMAIL_FROM=
# EMAIL_USER=
# ELASTIC_API_KEY=
